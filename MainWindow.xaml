<Window x:Class="CodePrompter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Code Prompter"
        Width="1100"
        Height="760"
        MinWidth="940"
        MinHeight="680"
        Background="#F3EFE7">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24" CornerRadius="28" Background="#183A37">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Code Prompter"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#F6F1E9" />
                    <TextBlock Margin="0,8,0,0"
                               Text="TXT-файлы лежат рядом с программой, NumPad 1-9 переключает тексты, copy из IDE синхронизирует позицию."
                               FontSize="15"
                               TextWrapping="Wrap"
                               Foreground="#D5E4DA" />
                </StackPanel>

                <Border Grid.Column="1" Padding="16" CornerRadius="20" Background="#F4C95D">
                    <StackPanel>
                        <TextBlock Text="Бинды" FontWeight="Bold" Foreground="#4B3707" />
                        <TextBlock Margin="0,8,0,0" Text="NumPad1-9 - загрузка txt" Foreground="#4B3707" />
                        <TextBlock Text="NumPad0 - обновить список" Foreground="#4B3707" />
                        <TextBlock Text="NumPad* - sync по буферу" Foreground="#4B3707" />
                        <TextBlock Text="Ctrl+A, Ctrl+C - авто sync" Foreground="#4B3707" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="5" HorizontalAlignment="Stretch">
            <Border Margin="0,0,12,0" Padding="16" CornerRadius="18" Background="#FFFFFF">
                <StackPanel>
                    <TextBlock Text="Статус" Foreground="#6B7280" />
                    <TextBlock x:Name="StatusTextBlock" Margin="0,10,0,0" FontSize="18" FontWeight="SemiBold" Text="-" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,12,0" Padding="16" CornerRadius="18" Background="#FFFFFF">
                <StackPanel>
                    <TextBlock Text="Файл" Foreground="#6B7280" />
                    <TextBlock x:Name="ActiveScriptTextBlock" Margin="0,10,0,0" FontSize="18" FontWeight="SemiBold" Text="-" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,12,0" Padding="16" CornerRadius="18" Background="#FFFFFF">
                <StackPanel>
                    <TextBlock Text="Позиция" Foreground="#6B7280" />
                    <TextBlock x:Name="IndexTextBlock" Margin="0,10,0,0" FontSize="18" FontWeight="SemiBold" Text="0 / 0" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,12,0" Padding="16" CornerRadius="18" Background="#FFFFFF">
                <StackPanel>
                    <TextBlock Text="Режим" Foreground="#6B7280" />
                    <TextBlock x:Name="ModeTextBlock" Margin="0,10,0,0" FontSize="18" FontWeight="SemiBold" Text="Ожидание" />
                </StackPanel>
            </Border>
            <Border Padding="16" CornerRadius="18" Background="#FFFFFF">
                <StackPanel>
                    <TextBlock Text="Текущая строка" Foreground="#6B7280" />
                    <TextBlock x:Name="CurrentLineTextBlock" Margin="0,10,0,0" FontSize="16" FontWeight="SemiBold" Text="-" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="20" CornerRadius="24" Background="#FFFFFF">
                <StackPanel>
                    <TextBlock Text="Управление" FontSize="20" FontWeight="SemiBold" />
                    <Button x:Name="RefreshButton" Margin="0,18,0,0" Height="44" Click="RefreshButton_Click" Content="Обновить TXT-файлы" />
                    <Button x:Name="StartButton" Margin="0,12,0,0" Height="44" Click="StartButton_Click" Content="Запустить хук" />
                    <Button x:Name="StopButton" Margin="0,12,0,0" Height="44" Click="StopButton_Click" Content="Остановить хук" />
                    <Button x:Name="ResetButton" Margin="0,12,0,0" Height="44" Click="ResetButton_Click" Content="Сбросить позицию" />
                    <Button x:Name="SyncButton" Margin="0,12,0,0" Height="44" Click="SyncButton_Click" Content="Sync из буфера" />
                    <CheckBox x:Name="OverlayCheckBox"
                              Margin="0,14,0,0"
                              IsChecked="True"
                              Checked="OverlayCheckBox_Changed"
                              Unchecked="OverlayCheckBox_Changed"
                              Content="Визуальная подсказка" />
                    <TextBlock Margin="0,12,0,0" Text="Размер текста подсказки" />
                    <Slider x:Name="OverlayFontSizeSlider"
                            Margin="0,6,0,0"
                            Minimum="14"
                            Maximum="32"
                            Value="18"
                            TickFrequency="2"
                            IsSnapToTickEnabled="True"
                            ValueChanged="OverlayFontSizeSlider_ValueChanged" />

                    <Border Margin="0,24,0,0" Padding="16" CornerRadius="18" Background="#EEF2F6">
                        <StackPanel>
                            <TextBlock Text="Доступные бинды" FontWeight="SemiBold" />
                            <TextBlock x:Name="ScriptsTextBlock"
                                       Margin="0,10,0,0"
                                       FontFamily="Cascadia Code"
                                       Text="Нет TXT-файлов"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="20" CornerRadius="24" Background="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Активный код" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="2"
                               x:Name="PreviewTextBlock"
                               Foreground="#6B7280"
                               Text="-"
                               TextWrapping="Wrap" />
                    <TextBox x:Name="CodeTextBox"
                             Grid.Row="4"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontSize="15"
                             FontFamily="Cascadia Code" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
