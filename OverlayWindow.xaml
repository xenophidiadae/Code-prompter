<Window x:Class="CodePrompter.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="260"
        Height="84"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Grid IsHitTestVisible="False">
        <!-- Плашка (Border) полностью удалена -->
        
        <TextBlock x:Name="OverlayTextBlock"
                   Foreground="#666666" 
                   FontSize="11" 
                   FontWeight="Thin"
                   TextWrapping="Wrap"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Right"
                   TextAlignment="Right"
                   Opacity="0.2" 
                   FontFamily="Consolas, Cascadia Code"
                   Margin="0,0,15,10"
                   Text="-" />
    </Grid>
</Window>